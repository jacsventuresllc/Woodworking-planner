generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  subscription  String    @default("free") // free, pro
  projects      Project[]
}

model Project {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  name          String
  imageUrl      String?
  status        String    @default("draft") // draft, complete
  
  // JSON fields for AI-generated content
  components    String?   // JSON array of detected components
  bom           String?   // JSON array of BOM items
  cutList       String?   // JSON array of cut list items
  instructions  String?   // JSON array of assembly steps
  
  // Settings
  skillLevel    String    @default("beginner") // beginner, intermediate
  kerfWidth     Float     @default(3.0) // mm
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}